# MusIQ-Lab — local environment variables
#
# Copy this file to .env and fill in the values you want. .env is gitignored;
# never commit real keys. The pipeline reads everything through analyze/keys.py
# and python-dotenv; missing values soft-fail the relevant feature, they don't
# break the analysis.

# ---- API keys ----

# AcoustID (Chromaprint → MusicBrainz lookup), used by analyze/stages/identify.py.
# Register an Application key (NOT a user account key) at:
#   https://acoustid.org/applications  →  Register Application
# Without this, the identify stage soft-fails and tracks show as unidentified.
ACOUSTID_API_KEY=

# Last.fm (genre tags + similar artists), used by webui's Metadata card.
# Register an API account at:
#   https://www.last.fm/api/account/create
# Without this, the Last.fm card shows "unavailable" but everything else works.
LASTFM_API_KEY=

# ---- Optional path overrides ----
# All of these have sensible defaults; only set them if you have a canonical
# local layout.

# yt-dlp binary (consumed by webui/webui/analyze_runner.py). Defaults to
# `yt-dlp` on PATH. Set this if the binary lives somewhere not on PATH —
# e.g. on Windows, set it to the full path of yt-dlp.exe.
# MUSIQ_YTDLP_BIN=

# Directory where YouTube downloads land. Defaults to ~/Videos/musiq-lab.
# MUSIQ_YT_OUT_DIR=

# MP3 batch-test corpus directory for install-logs/batch-test.sh and
# install-logs/rederive-batch.sh. Defaults to ~/Music/musiq-lab-test.
# MUSIQ_MP3_DIR=
