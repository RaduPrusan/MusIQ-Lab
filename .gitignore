.omx/

# ===== Pipeline-generated artifacts =====
# Stems, MIDI, F0 arrays, JAMS, and summary JSONs — all regenerable from the
# source MP3 via `python -m analyze`. Tests use synthetic fixtures (see
# webui/tests/conftest.py); the integration test against a real cache skips
# cleanly when the cache is absent. Nothing under cache/ is source code.
cache/

# ===== Vendored third-party models =====
# Populated by scripts/install-*.sh from the original sources. We don't
# redistribute the code or weights through this repo; see analyze/vendor/README.md.
analyze/vendor/larsnet/*
!analyze/vendor/larsnet/.gitkeep

# Chromaprint fpcalc binary (vendored by scripts/install-chromaprint.sh,
# v1.5.1 Linux x86_64 build, ~1MB). Not redistributed through this repo.
analyze/vendor/chromaprint/*
!analyze/vendor/chromaprint/.gitkeep

# Essentia high-level SVM models (downloaded by scripts/install-essentia.sh,
# hosted by MTG, CC BY-NC-SA 4.0 — see analyze/vendor/README.md).
# ~14MB total, not redistributed through this repo.
analyze/vendor/essentia-models/*
!analyze/vendor/essentia-models/.gitkeep

